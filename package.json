{
  "name": "nexus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "npm run build:css && wrangler deploy",
    "deploy:staging": "npm run build:css && wrangler deploy --env staging",
    "build:css": "tailwindcss --input tailwind/input.css --output tailwind/output.css --content 'src/**/*.ts' --minify && node scripts/embed-css.js",
    "typecheck": "tsc --noEmit",
    "test": "echo \"No tests yet\"",
    "test:smoke": "playwright test",
    "test:smoke:staging": "BASE_URL=https://nexus-staging.stevencolecobb.workers.dev playwright test",
    "test:smoke:prod": "BASE_URL=https://nexus.keylightdigital.dev SKIP_AUTH_TESTS=1 playwright test",
    "test:webhooks": "npx tsx test/stripe-webhooks.ts",
    "migrations:local": "wrangler d1 migrations apply nexus-db --local",
    "migrations:staging": "wrangler d1 migrations apply nexus-db-staging --env staging --remote",
    "seed-demo:local": "wrangler d1 execute nexus-db --local --file=scripts/seed-demo.sql",
    "seed-demo:staging": "wrangler d1 execute nexus-db-staging --env staging --remote --file=scripts/seed-demo.sql",
    "seed-demo:prod": "wrangler d1 execute nexus-db --remote --file=scripts/seed-demo.sql"
  },
  "dependencies": {
    "@sentry/cloudflare": "^10.47.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/cli": "^4.2.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.5.0",
    "wrangler": "^3.80.0"
  }
}
